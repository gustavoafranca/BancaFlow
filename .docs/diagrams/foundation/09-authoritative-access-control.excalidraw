    {
      "type": "text",
      "id": "rule-text",
      "x": 2500,
      "y": 955,
      "width": 260,
      "height": 270,
      "text": "Regra de dependência\n\nAccess Control → shared\nIdentity → sua porta\nParticipants → contrato público\nBackend → adapters\n\nPROIBIDO:\nAccess Control → Identity\n\nSem ciclo entre bounded contexts.",
      "fontSize": 15,
      "strokeColor": "#343a40",
      "frameId": null
    }
