DATABASE_URL="postgresql://docker:docker@localhost:5432/docker?schema=public"
PORT="4000"
NODE_ENV="development"

# Identity — tokens e criptografia. OBRIGATÓRIOS, >= 32 caracteres e DIFERENTES
# entre si — o backend falha no startup (exit 1) se ausentes/fracos/iguais.
JWT_SECRET="YOUR_SECRET_HERE_WITH_AT_LEAST_32_CHARACTERS"
# Segredo próprio para o digest HMAC-SHA-256 do refresh token (distinto do JWT_SECRET)
REFRESH_TOKEN_SECRET="YOUR_REFRESH_SECRET_HERE_WITH_AT_LEAST_32_CHARS"
ACCESS_TOKEN_TTL_MINUTES="60"
REFRESH_TOKEN_TTL_DAYS="7"
BCRYPT_ROUNDS="12"

# Identity — resolução de tenant por host
#
# --- PERFIL DE DESENVOLVIMENTO LOCAL E E2E (valor deste template) ---
# ".localhost" resolve para 127.0.0.1 nativamente em Chromium/Firefox (RFC
# 6761), sem precisar editar /etc/hosts: qualquer host "<codigoBanca>.localhost"
# (ex.: farizeu.localhost, pw-e2e.localhost) já funciona de ponta a ponta.
BANCA_HOST_SUFFIX=".localhost"
#
# --- PRODUÇÃO ---
# Configure via variável de ambiente do deploy, não editando este arquivo:
# BANCA_HOST_SUFFIX=".bancaflow.com.br"
#
# X-Forwarded-Host só é honrado quando TRUST_PROXY_HOST=true E o peer TCP
# imediato está em TRUSTED_PROXY_IPS (aceita IP exato, IPv6 e CIDR, ex.:
# "172.18.0.0/16"; IPv4 mapeado em IPv6 como "::ffff:127.0.0.1" é normalizado).
#
# --- PERFIL DE DESENVOLVIMENTO LOCAL (este template é de dev) ---
# Para o fluxo local funcionar de ponta a ponta, o Next (apps/web em :3000)
# reescreve /api para o backend em :4000 preservando o host original via
# X-Forwarded-Host. Como o Next dev conversa com o backend por loopback, os
# valores abaixo permitem que esse host seja honrado — nenhuma entrada em
# /etc/hosts é necessária com o sufixo ".localhost" acima.
TRUST_PROXY_HOST="true"
TRUSTED_PROXY_IPS="127.0.0.1,::1,::ffff:127.0.0.1"
#
# --- PRODUÇÃO ---
# Use o(s) IP(s)/CIDR REAIS do proxy de borda (nginx/load balancer) e NUNCA
# loopback. Se o backend não fica atrás de proxy que injeta X-Forwarded-Host,
# deixe TRUST_PROXY_HOST="false" e TRUSTED_PROXY_IPS="" (falha fechada).

# CORS — lista de origens permitidas separada por vírgula (credentials: true)
CORS_ORIGINS="http://localhost:3000"
